---
import BaseLayout from "../layouts/base-layout.astro";
import { getCollection } from "astro:content";
import type { BlogType } from "../content/config";

const blogs = await getCollection("blog", ({ data }) => data.published === true);
blogs.sort((a, b) => Date.parse(b.data.date) - Date.parse(a.data.date));
const recentPosts = blogs.slice(0, 5);
---

<BaseLayout title="Weibo Zhang">
    <main class="max-w-lg tracking-tight mx-auto mt-10">
        <h1 class="text-2xl font-cal text-zinc-900">Weibo Zhang</h1>
        <p class="mt-1 text-sm font-light text-zinc-400">Thinking about creating something...</p>

        <p class="mt-6 text-sm leading-relaxed text-zinc-600">
            Hi, I'm Weibo. I'm graduating from college this semester in CS. I am not sure what I want to do yet but I
            would like to create if I can.
        </p>

        <div class="flex gap-4 mt-4 text-sm">
            <a
                href="https://github.com/Theonlyhamstertoh"
                target="_blank"
                rel="noopener"
                class="text-zinc-500 underline hover:text-zinc-800 transition-colors"
            >
                GitHub
            </a>
            <a
                href="https://www.linkedin.com/in/weibozhang/"
                target="_blank"
                rel="noopener"
                class="text-zinc-500 underline hover:text-zinc-800 transition-colors"
            >
                LinkedIn
            </a>
            <a
                href="https://open.spotify.com/user/eswggww5eu0qes3rs778hsrxj?si=8395e09dbdb34a56"
                target="_blank"
                rel="noopener"
                class="text-zinc-500 underline hover:text-zinc-800 transition-colors"
            >
                Spotify
            </a>
            <a
                href="https://discord.gg/sjNE8rPSMM"
                target="_blank"
                rel="noopener"
                class="text-zinc-500 underline hover:text-zinc-800 transition-colors"
            >
                Discord
            </a>
        </div>

        <!-- Recent Writing -->
        <section class="mt-14">
            <h2 class="text-sm text-zinc-400 font-medium mb-3">Writing</h2>
            <ul>
                {
                    recentPosts.map(({ data, slug }: { data: BlogType; slug: string }) => {
                        const d = new Date(data.date);
                        return (
                            <li>
                                <a
                                    href={`/blog/${slug}`}
                                    class="flex items-baseline justify-between gap-4 py-2 text-zinc-600 hover:text-zinc-900 transition-colors"
                                >
                                    <span class="text-sm truncate">{data.title}</span>
                                    <span class="text-xs text-zinc-400 shrink-0 tabular-nums">
                                        {d.toLocaleString("en-us", {
                                            month: "short",
                                            day: "numeric",
                                            year: "numeric",
                                        })}
                                    </span>
                                </a>
                            </li>
                        );
                    })
                }
            </ul>
            <a
                href="/blog"
                class="inline-block mt-3 text-sm font-medium text-zinc-700 underline hover:text-zinc-600 transition-colors"
            >
                All posts &rarr;
            </a>
        </section>
    </main>
</BaseLayout>
